# ----- checking data consistancy and unwanted errors in data -------

select cst_id, count(*) from crm_cust_info
group by cst_id
having count(*) > 1;

select * from crm_cust_info
where cst_id =29466;

# checking duplicate data

select * from(
select *, row_number() over( partition by Cst_id order by cst_create_date desc)  as flang
from crm_cust_info) t
where flang = 1;

# checking unwanted spaces

select cst_firstname from crm_cust_info
where cst_firstname != trim(cst_firstname);


select cst_lastname from crm_cust_info
where cst_lastname != trim(cst_lastname);

select cst_gndr from crm_cust_info
where cst_gndr != trim(cst_gndr);

