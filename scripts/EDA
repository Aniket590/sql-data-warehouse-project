SELECT * FROM warehouse.gold_dim_customers;

create database EDA;
use EDA;

create table customer_info(
Customer_key int,
customer_id int,
customer_number varchar(255),
First_name varchar(255),
country varchar(255),
Gender varchar(255),
Marital_status varchar(255),
Birth_day Date,
Create_date date)
as
select * from warehouse.gold_dim_customers;

select * from customer_info;

select * from gold_dim_product;

drop table Product_info;

create table Product_info(
Product_key int,
Product_ID int,
Product_name varchar(255),
Product_number varchar(255),
Category_id varchar(255),
Catogery varchar(255),
SubCategory varchar(255),
Product_cost int,
Maintenance varchar(255),
Product_line varchar(255),
Start_date Date)
as 
select * from gold_dim_product;

select * from product_info;
select * from gold_fact_sales;

drop table Sales_info;
create table Sales_info(
Order_number varchar(255),
Product_key int,
Customer_key int,
Order_date date,
ShippingDate date,
Due_date date,
Sales_amount int,
Quantity int,
Price int)
as 
select * from gold_fact_sales;

select * from sales_info;
select * from customer_info;
select * from Product_info;



select distinct(catogery), SubCategory from product_info
order by Catogery;


# exploring table schema 

select * from information_schema.tables
where table_schema = 'warehouse';

select * from information_schema.columns
where table_name = 'customer_info';

#  exploring the tables in database

select distinct(country) from customer_info;


select distinct catogery, SubCategory, product_name from product_info
order by 1,2,3;

select max(start_date), min(start_date) from product_info;

select 
max(order_date), min(order_date),
datediff( min(order_date), max(order_date)) as difference
from sales_info;

select 
max(order_date), min(order_date),
timestampdiff( month,min(order_date), max(order_date)) as difference
from sales_info;


# find the total sales

select sum(sales_amount) as total_sales from sales_info;

# find how many items are sold

select sum(quantity) as total_quantity from sales_info;

# find the average salling price

select avg(price) as average_price from sales_info;

# find the total number of orders

select count(distinct(order_number)) as total_order from sales_info;

# find the total number of products

select count(distinct(product_key)) as total_products from sales_info;

# find the total number of customers

select count(distinct(customer_key)) as total_customers from sales_info;

# find the total number of customers that has placed an order.

select count(distinct(customer_key)) as total_customers from sales_info;


## Generate report to show all big Matrix of business


select 'Total_Sales' as measure_name, sum(sales_amount) as measure_value from sales_info
union all
select 'Total_Customers' as Measure_name , count(distinct(customer_key)) as measure_value from sales_info
union all
select 'Total_Quantity' as Measure_name, sum(quantity) as measure_value from sales_info
union all
select ' Total_Products' as measure_name, count(distinct(product_key)) as measure_value from sales_info
union all
select 'total_orders' as measure_name, count(distinct(order_number)) as measure_value from sales_info
union all
select 'Average_Price' as measure_name, avg(price) as measure_vaqlue from sales_info;

select * from sales_info;
select * from customer_info;
select * from Product_info;

### find total customers by countries

select country, count(distinct(customer_id)) as Total_customer 
from customer_info
group by country;

# find total product by category

select catogery, count(distinct(product_id))
from product_info
group by catogery;

# find total customer by gender

select gender, count(distinct(customer_id)) as Total_customer 
from customer_info
group by gender;

# what is the average costs in each category

select catogery, avg(product_cost) as Average_cost
from product_info
group by catogery;

# what is the revenue generated for each category?

select  t2.Catogery,
sum(t1.sales_amount) from sales_info t1
left join 
product_info t2 
on t1.product_key = t2.product_key
group by catogery ;

# find total revenue is generated by each customer

select t1.customer_key, t2.First_name,
sum(t1.sales_amount) as revenue from sales_info t1
left join customer_info t2
on t1.customer_key = t2.Customer_Key
group by customer_key, First_name
order by sum(t1.sales_amount) desc
limit 10;

# what is the distribution of sold items across countries

select t2.country,
sum(t1.quantity) as sold_units from sales_info t1
left join customer_info t2
on t1.customer_key = t2.Customer_Key
group by country;


# which 5 product generate the highest revenue

select t2.product_name, sum(t1.Sales_amount) from sales_info t1
left join product_info t2
on t1.Product_key = t2.Product_key
group by t2.product_name
order by sum(t1.sales_amount) desc
limit 5;

# which are the wrost 5 performing product

select t2.product_name, sum(t1.Sales_amount) from sales_info t1
left join product_info t2
on t1.Product_key = t2.Product_key
group by t2.product_name
order by sum(t1.sales_amount)
limit 5;

# which are best performing product in each subcategory


select t2.SubCategory, sum(t1.Sales_amount) from sales_info t1
left join product_info t2
on t1.Product_key = t2.Product_key
group by t2.SubCategory
order by sum(t1.sales_amount) desc
limit 5;


with fear as(
select t2.Catogery,t2.product_name, sum(t1.Sales_amount) as tre from sales_info t1
left join product_info t2
on t1.Product_key = t2.Product_key
group by t2.Catogery,t2.product_name
order by sum(t1.sales_amount)) 
select  catogery, product_name, max(tre) from fear
group by catogery;
