
/* 
## Customer Report
==========================================================
Purpose:
	- This report consolidate key Customer matrix and behaviors.
    
Highlights:
   1.) retrive core columns from tables
   2.) segment the customer into categories (vip, regular, new) and age group. 
   3.) aggrigate customer level metrix:
		- total orders
        - total sales
        - total quantity
        - lifespan( in month)
        - total products

	4.) calculate valuable KPIs:
		- recency (months since last sales)
		- average order revenue(AOR)
		- average monthly revenue
===================================================================    
   */

create view report_customer as                 -- 1.) retrive core columns from tables
   with base_query as(
   select order_number, 
   product_key,
   sales_amount,
   order_date,
   quantity,
  c.customer_key,
   customer_number,
   first_name as customer_name,
   birth_day,
   timestampdiff(year, c.birth_day, curdate()) as age
   from sales_info s
   left join customer_info c 
   on s.customer_key = c.customer_key
   where order_date is not null),
   customer_aggrigation as(
   select                                                --  aggrigate customer level metrix:
	   customer_number,
	   customer_key,
	   customer_name,
	   age,
	   count(distinct(order_number)) as total_orders, 
	   sum(sales_amount) as total_sales,
	   sum(quantity) as order_quantity,
	   max(order_date) as last_order_date,
	   count(distinct(product_key)) as product_orders,
       timestampdiff(month, min(order_date), max(order_date)) as lifespan
   from base_query
   group by    customer_number,
				customer_key,
				customer_name,
				age)
                
  select customer_number,                                         -- calculate valuable KPIs:
  customer_key,
  customer_name,
  age,
  case when age < 20 then 'under 20'
		when age between 20 and 29 then '20-29'
        when age between 30 and 39 then '30-39'
        when age between 40 and 49 then '40-49'
        else '50 and above'
        end age_group,
  total_orders,
  total_sales,
  order_quantity,
  last_order_date,
  product_orders,
  lifespan,
  case when lifespan > 12 and total_sales > 5000 then 'VIP_customer'
		when lifespan > 12 and total_sales <= 5000 then 'Regular_customer'
        else "New customer"
        end Customer_segment,
timestampdiff(month, last_order_date, curdate()) as recency,                    --  recency (months since last sales)
case when total_orders = 0 then '0'
	else (total_sales/ total_orders ) 
    end average_sales,                                                          --  average order revenue(AOR)
case when lifespan = 0 then total_sales
	else (total_sales/ lifespan)
    end montly_revenue                                                           --  average monthly revenue
  from customer_aggrigation; 

